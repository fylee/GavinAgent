DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_db
DATABASE_NAME=agent_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

REDIS_URL=redis://localhost:6379/0

# Agent timezone for datetime display and workflow cron scheduling
# IANA timezone name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
AGENT_TIMEZONE=Asia/Taipei

# Absolute path to the agent workspace directory.
# Default: <project_root>/agent/workspace
# On Windows, set this explicitly if Path.resolve() gives a different path (e.g. via symlinks/junctions):
# AGENT_WORKSPACE_DIR=C:\Users\you\project\agent\workspace

# Max recent chat messages to include as LLM context (prevents old/poisoned history confusion)
# AGENT_HISTORY_WINDOW=10

# Optional — leave blank to disable Telegram bot
TELEGRAM_BOT_TOKEN=

LITELLM_DEFAULT_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# MCP secret encryption (generate with: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# Required only if you use MCP servers. Leave blank otherwise.
FERNET_KEY=
FERNET_KEY_PREVIOUS=
